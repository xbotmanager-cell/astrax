/**
 * AstraX - plugins/commands/owner/botname.js
 * Change bot display name
 * Max 25 characters - no hardcoded defaults
 */

export default {
  name: 'botname',
  alias: ['setname', 'namebot', 'changename'],
  desc: 'Change or reset bot display name',
  category: 'owner',
  usage: '.botname <new_name> | .botname reset',
  permission: 'owner',

  async execute(sock, m, args, { db, logger, contextInfo, from, prefix }) {
    try {
      const [currentName, defaultName] = await Promise.all([
        db.get('botname'),
        db.get('default_botname')
      ])

      const fallbackName = defaultName || 'Bot'
      const actualCurrent = currentName || fallbackName
      const input = args.join(' ').trim()

      // в”Җв”Җв”Җ IF NO ARGS: SHOW CURRENT NAME в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      if (!input) {
        const infoText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” BOT NAME гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ Current: ${actualCurrent}
в”Ӯ в—Ұвһӣ Default: ${fallbackName}
в”Ӯ в—Ұвһӣ Max: 25 characters
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·

в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” COMMANDS гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ ${prefix}botname ${fallbackName}
в”Ӯ в—Ұвһӣ ${prefix}botname MyBot Pro
в”Ӯ в—Ұвһӣ ${prefix}botname reset
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
        return await sock.sendMessage(from, {
          text: infoText.trim(),
          contextInfo
        }, { quoted: m })
      }

      // в”Җв”Җв”Җ RESET TO DEFAULT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      if (input.toLowerCase() === 'reset' || input.toLowerCase() === 'default') {
        if (actualCurrent === fallbackName) {
          const infoText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” INFO гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ Name is already default
в”Ӯ в—Ұвһӣ Current: ${fallbackName}
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
          return await sock.sendMessage(from, {
            text: infoText.trim(),
            contextInfo
          }, { quoted: m })
        }

        await db.set('botname', fallbackName)

        const successText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” BOT NAME RESET гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ From: ${actualCurrent}
в”Ӯ в—Ұвһӣ To: ${fallbackName}
в”Ӯ в—Ұвһӣ Status: Default вң…
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
        await sock.sendMessage(from, {
          text: successText.trim(),
          contextInfo
        }, { quoted: m })

        logger.success('BOTNAME', `Bot name reset to ${fallbackName} by ${m.key.participant || from}`)
        return
      }

      // в”Җв”Җв”Җ VALIDATE NAME в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      if (input.length > 25) {
        const errorText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” ERROR гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ Too long
в”Ӯ в—Ұвһӣ Max: 25 characters
в”Ӯ в—Ұвһӣ Your input: ${input.length}
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
        return await sock.sendMessage(from, {
          text: errorText.trim(),
          contextInfo
        }, { quoted: m })
      }

      if (input.length < 2) {
        const errorText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” ERROR гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ Too short
в”Ӯ в—Ұвһӣ Min: 2 characters
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
        return await sock.sendMessage(from, {
          text: errorText.trim(),
          contextInfo
        }, { quoted: m })
      }

      // в”Җв”Җв”Җ CHECK IF SAME в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      if (actualCurrent === input) {
        const infoText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” INFO гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ Name is already ${input}
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
        return await sock.sendMessage(from, {
          text: infoText.trim(),
          contextInfo
        }, { quoted: m })
      }

      // в”Җв”Җв”Җ SET NEW NAME в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      await db.set('botname', input)

      const isDefault = input === fallbackName
      const statusText = isDefault ? 'Default вң…' : 'Custom вң…'

      const successText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” BOT NAME CHANGED гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ From: ${actualCurrent}
в”Ӯ в—Ұвһӣ To: ${input}
в”Ӯ в—Ұвһӣ Status: ${statusText}
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
      await sock.sendMessage(from, {
        text: successText.trim(),
        contextInfo
      }, { quoted: m })

      logger.success('BOTNAME', `Bot name changed from ${actualCurrent} to ${input} by ${m.key.participant || from}`)

    } catch (e) {
      logger.error('BOTNAME', 'Failed to set bot name', e.message)

      const errorText = `
в•ӯв”Җв”Җв”Җв”Җв”ҖгҖ” ERROR гҖ•в”Җв”Җв”Җв”Җв”Җв”ҲвҠ·
в”Ӯ в—Ұвһӣ ${e.message}
в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҠ·
`
      await sock.sendMessage(from, {
        text: errorText.trim(),
        contextInfo
      }, { quoted: m })
    }
  }
}